{
  "schemaVersion": 1,
  "id": "hungerbridge",
  "version": "${version}",
  "name": "HungerBridge",
  "description": "Multiloader HTTP bridge for Paper and Fabric.",
  "authors": ["iFamished"],
  "license": "MIT",
  "environment": "server",

  "entrypoints": {
    "server": [
      "com.hungerbridge.fabric.HungerBridgeFabric"
    ]
  },

  "mixins": [
    "hungerbridge.mixins.json"
  ],

  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": ">=1.21.11"
  }
}
