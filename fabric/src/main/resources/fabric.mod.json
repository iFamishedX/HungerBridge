{
  "schemaVersion": 1,
  "id": "hungerbridge",
  "version": "1.0.0",
  "name": "HungerBridge",
  "description": "Multiloader HTTP bridge for Paper and Fabric.",
  "authors": ["iFamished"],
  "license": "MIT",
  "environment": "server",

  "entrypoints": {
    "server": [
      "com.hungerbridge.fabric.HungerBridgeFabric"
    ],
    "preLaunch": [
      "com.hungerbridge.fabric.AgentPreLaunch"
    ]
  },

  "mixins": [
    "hungerbridge.mixins.json"
  ],

  "depends": {
    "fabricloader": ">=0.19.2",
    "minecraft": ">=1.21.11"
  }
}
